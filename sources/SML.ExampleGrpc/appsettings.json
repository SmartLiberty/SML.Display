{
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DbContext": "Host=${SML_DATABASE:URL?localhost}; Port=${SML_DATABASE:PORT?5432}; Database='SML.ExampleGrpc'; Username='${SML_DATABASE:USER?postgres}'; Password='${SML_DATABASE:PASSWORD?postgresPWD}'"
  },

  "GeneralSettings": {
    "ServiceName": "SML.ExampleGrpc",
    "ServiceDescription": "This is just an example for SML.ExampleGrpc. It should be replaced when the service is finished (don't forget project properties -> package)"
  },

  "GrpcExampleClientSettings": {
    "Url": "https://${SML_SITE:URL?localhost}:${SML_EXAMPLE:HTTPS_PORT?30000}",
    "RetryPolicy": {
      "MaxAttempts": 30,
      "InitialBackoff": "00:00:01",
      "MaxBackoff": "00:00:05",
      "BackoffMultiplier": 1.5,
      "RetryableStatusCodes": [ "Unavailable" ]
    }
  },

  "Install": {
    "Data": ""
  },

  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    },
    "EndPoints": {
      "Https": {
        "Url": "https://${SML_SITE:URL?localhost}:${SML_EXAMPLE:HTTPS_PORT?30xxx}[TODO GET AN AVAILABLE PORT HERE : https://smartliberty.knowledgebase.co/secure/11/grpc-ports-list-279.html]"
      }
    },
    "Certificates": {
      "Default": {
        "PollingInterval": "1.00:00:00"
      }
    }
  },

  "LifeTimeSettings": {
    "ArchivedExamplesDays": 30
  },

  "LogSettings": {
    "Config": "./NLog.config"
  },

  "PostgresReconnectionSettings": {
    "RetryInterval": "00:00:30",
    "NumberOfRetriesBeforeKill": 3
  },

  "RabbitMqSettings": {
    "HostName": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "MaxAttempts": 30,
    "InitialBackoff": "00:00:01",
    "MaxBackoff": "01:00:00",
    "BackoffMultiplier": 1.5
  },

  "RecurringJobSettings": {
    "Watchdog": {
      "JobInterval": "00:00:55"
    },
    "CleanArchives": {
      "JobInterval": "1.00:00:00",
      "FailedJobSettings": {
        "MaxAttempts": 30,
        "InitialBackoff": "00:01:00",
        "MaxBackoff": "01:00:00",
        "BackoffMultiplier": 1.5
      }
    },
    "LoggOneLine": {
      "JobInterval": "1.00:00:00"
    }
  },

  "Site": {
    "Language": "en"
  },

  "WatchdogClientSettings": {
    "ServiceExe": "SML.ExampleGrpc.exe",
    "Period": 60,
    "GracePeriod": 120
  },
  
  "Serilog": {
    "MinimumLevel": "Information"
  }
}
